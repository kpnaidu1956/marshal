# ============================================================
# Marshal — Configuration
# Copy this file to .env and fill in your values
# ============================================================

# === Required ===
POSTGRES_DATABASE=marshal_db
POSTGRES_USER=marshal_app
POSTGRES_PASSWORD=changeme-use-a-strong-password

# JWT secret for PostgREST — must be at least 32 characters
# Generate with: openssl rand -base64 48
POSTGREST_JWT_SECRET=your-jwt-secret-minimum-32-characters-long

# === LLM Provider (pick one) ===
# Options: "ollama" (default, free, local), "openai", "anthropic"
LLM_PROVIDER=ollama

# Ollama (default — no API key needed, runs locally)
# Models are pulled automatically on first use
# OLLAMA_BASE_URL=http://ollama:11434

# OpenAI (uncomment to use)
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_EMBED_MODEL=text-embedding-3-small

# Anthropic (uncomment to use — needs Ollama or OpenAI for embeddings)
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-sonnet-4-20250514
# EMBED_PROVIDER=ollama

# === Branding ===
APP_NAME=Marshal
APP_DOMAIN=localhost
APP_COLOR=#7C83BC
APP_PORT=80

# === Platform Admin ===
# Comma-separated list of emails with full platform admin access
SUPER_ADMIN_EMAILS=admin@example.com

# === Email (optional — registration works without, but no verification emails) ===
# Sign up at https://resend.com for a free API key
# RESEND_API_KEY=re_...
# RESEND_FROM_ADDRESS=Marshal <noreply@your-domain.com>

# === reCAPTCHA (optional — registration works without, but no bot protection) ===
# Get keys at https://www.google.com/recaptcha/admin (v3)
# RECAPTCHA_SITE_KEY=
# RECAPTCHA_SECRET_KEY=

# === Trial Settings ===
TRIAL_DURATION_DAYS=90
TRIAL_MAX_USERS=25
TRIAL_MAX_STORAGE_GB=10
TRIAL_MAX_DOCUMENTS=200

# === GCP Storage (optional — only needed if using GCS for file storage) ===
# GCS_BUCKET=your-bucket
# GCP_PROJECT_ID=your-project
