# Build React frontend
FROM node:20-alpine AS builder

WORKDIR /app
COPY crates/marshal-ui-react/package.json crates/marshal-ui-react/package-lock.json ./
RUN npm ci

COPY crates/marshal-ui-react/ .
RUN npx vite build

# Serve with Caddy
FROM caddy:2-alpine

COPY --from=builder /app/dist /srv/dist
COPY docker/Caddyfile.frontend /etc/caddy/Caddyfile

USER nobody

EXPOSE 80
